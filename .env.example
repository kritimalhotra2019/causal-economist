# --- Agent LLM (the economist's reasoning + the critic's written judgement) ---
# Required only for --provider nebius. The offline stub provider needs nothing.
NEBIUS_API_KEY=
# Leave BLANK to use the per-role defaults (economist=DeepSeek-V4-Pro,
# critic=Nemotron-3-Ultra-550B). Setting a value forces BOTH roles to it.
NEBIUS_MODEL=

# --- Eval baseline arms B / C / ablation (the one-shot comparisons) ---
# Required only to run the baseline arms. Arm A (MAS) runs without a key via stub.
ANTHROPIC_API_KEY=
# Set this to a current model id you have access to.
ANTHROPIC_MODEL=claude-sonnet-4-5

# --- Streamlit app gate ---
# The Streamlit app is fail-closed: it refuses to run unless this is set.
# On Streamlit Cloud, put this in the app's Secrets.
APP_PASSWORD=
